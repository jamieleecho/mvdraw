# Doxyfile for MVKit. Run from the mvkit/ directory:  doxygen Doxyfile
# Only non-default options are set; everything else uses Doxygen's defaults.

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "MVKit"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "An AppKit-inspired application framework for Multi-Vue on the Tandy Color Computer 3"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input -- the public API lives in the headers
#---------------------------------------------------------------------------
INPUT                  = include README.md USING.md
USE_MDFILE_AS_MAINPAGE = README.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = YES
STRIP_FROM_PATH        = include
STRIP_FROM_INC_PATH    = include

#---------------------------------------------------------------------------
# Build / extraction
#---------------------------------------------------------------------------
# C, not C++/Java: format output for C and treat all files as C.
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTENSION_MAPPING      = h=C
# Document only commented entities, and warn loudly about any public symbol
# that lacks a comment -- so `doxygen` doubles as a coverage check.
EXTRACT_ALL            = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
QUIET                  = NO

#---------------------------------------------------------------------------
# Comment parsing
#---------------------------------------------------------------------------
# First sentence of a /** */ block becomes the @brief automatically.
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
TAB_SIZE               = 4

# Function-like macros are part of MVKit's public API (MV_MENU, mv_set_menus,
# ...), so document them rather than skipping. Show macros as written; do not
# expand them in the generated docs.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO
SKIP_FUNCTION_MACROS   = NO

#---------------------------------------------------------------------------
# Output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
SORT_MEMBER_DOCS       = NO
